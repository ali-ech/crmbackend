PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/crm?retryWrites=true&w=majority
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
SUPERADMIN_EMAIL=admin@brokerage.com
SUPERADMIN_PASSWORD=changeme123
SUPERADMIN_NAME=Brokerage Owner
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379
# When true, SuperAdmin also gets in-app alerts on missed-task escalations (managers always do).
# Does NOT affect speed-to-lead or new-lead alerts (those go to managers/agents only).
NOTIFY_SUPERADMIN_ON_ESCALATION=false
# Minutes after a new lead is created with no activity before managers get a speed-to-lead alert.
SPEED_TO_LEAD_MINUTES=20
WHATSAPP_PROVIDER=ultramsg
ULTRAMSG_API_URL=https://api.ultramsg.com
# Send CRM alerts to agent's personal phone via their connected business WhatsApp instance
NOTIFY_WHATSAPP_PUSH=true
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
PUBLIC_SITE_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
BROKERAGE_TIMEZONE=+05:00
